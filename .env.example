# Site URL (for SEO, sitemaps, OG images)
NEXT_PUBLIC_SITE_URL=https://puretea.com
# Redirección tras el pago: en Shopify Admin → Checkout, pon como URL de estado del pedido: https://tudominio.com/checkout/success
FRONTEND_URL=https://puretea.com

# ——— Shopify Storefront API (SOLO esta API para carrito y productos; no Admin) ———
# Crear app: Settings → Apps and sales channels → Develop apps → Create app → Storefront API access
# Scopes obligatorios: unauthenticated_read_product_listings, unauthenticated_write_checkouts, unauthenticated_read_checkouts
# Token: el que te da la app (Storefront API access).
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_token
# Alternativo: SHOPIFY_STOREFRONT_TOKEN=your_storefront_token
SHOPIFY_API_VERSION=2024-01

# Cuenta y carrito (navbar)
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_SHOPIFY_ACCOUNT_URL=https://your-store.myshopify.com/account
