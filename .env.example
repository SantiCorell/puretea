# Copia a .env.local — no subas secretos a git

NEXT_PUBLIC_SITE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ——— Storefront API (productos, colecciones, carrito) ———
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=token_publico_storefront
SHOPIFY_STOREFRONT_ACCESS_TOKEN=token_publico_storefront
# Opcional: si la tienda no soporta la cadena por defecto (2026-01…2024-10), fija una versión.
# SHOPIFY_API_VERSION=2026-01

# Admin API (fallback servidor, shpat_)
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx

# ——— Customer Account API (OAuth Headless) ———
# ID de cliente público (app web) en el canal Headless
NEXT_PUBLIC_CUSTOMER_ACCOUNT_CLIENT_ID=

# URLs del terminal (tu panel Headless → API de cuenta de cliente)
NEXT_PUBLIC_SHOPIFY_CUSTOMER_AUTHORIZE_URL=https://shopify.com/authentication/TU_SHOP_ID/oauth/authorize
SHOPIFY_CUSTOMER_TOKEN_URL=https://shopify.com/authentication/TU_SHOP_ID/oauth/token
NEXT_PUBLIC_SHOPIFY_CUSTOMER_LOGOUT_URL=https://shopify.com/authentication/TU_SHOP_ID/logout

# Tras cerrar sesión en Shopify, a dónde volver (misma URL en Shopify → «URI de cierre de sesión»).
# NEXT_PUBLIC_CUSTOMER_POST_LOGOUT_REDIRECT_URI=https://www.tu-dominio.com/account

# URL exacta registrada en Shopify (Headless → redirect URIs). Customer Account API: HTTPS y sin localhost (usa ngrok en local).
# Ej. local: https://TU-DOMINIO.ngrok-free.app/api/auth/customer/callback (y la misma base en NEXT_PUBLIC_SITE_URL).
NEXT_PUBLIC_CUSTOMER_ACCOUNT_REDIRECT_URI=https://www.tu-dominio.com/api/auth/customer/callback
